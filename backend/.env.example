ENV=DEV
COMPOSE_PROJECT_NAME=tryniq
LOGGING_LEVEL_NAME=INFO

API_PORT=8000
API_WORKERS=1
API_ALLOWED_HOSTS=["*"]

POSTGRES_DATABASE=tryniq
POSTGRES_USER=tryniq
POSTGRES_PASSWORD=tryniq
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_TEST_URL=postgresql+asyncpg://test:test@localhost:5434/test_db
POSTGRES_POOL_SIZE=20
POSTGRES_MAX_OVERFLOW=200

MINIO_ENDPOINT_URL=http://minio:9000
MINIO_ACCESS_KEY=tryniq
MINIO_SECRET_KEY=tryniq-secret
MINIO_BUCKET=tryniq

REDIS_URL=redis://redis:6379/0

ASR_BACKEND=faster_whisper
ASR_MODEL=large-v3-turbo
ASR_DEVICE=cpu
ASR_COMPUTE_TYPE=int8
ASR_LANGUAGE=en
ASR_INITIAL_PROMPT="Tryniq, MinIO, TaskIQ, faster-whisper, large-v3-turbo, Postgres, pgvector, Redis, Next.js, FastAPI, Moonshine, Silero, Anthropic, Claude, Ollama, Qwen, Whisper, ECAPA, WebRTC, AudioWorklet, SQLModel, Alembic."

# optional
HF_TOKEN=<token>
