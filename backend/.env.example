ENV=DEV
COMPOSE_PROJECT_NAME=tryniq
LOGGING_LEVEL_NAME=INFO

API_PORT=8000
API_WORKERS=1
API_ALLOWED_HOSTS=["*"]

POSTGRES_DATABASE=tryniq
POSTGRES_USER=tryniq
POSTGRES_PASSWORD=tryniq
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_TEST_URL=postgresql+asyncpg://test:test@localhost:5434/test_db
POSTGRES_POOL_SIZE=20
POSTGRES_MAX_OVERFLOW=200

MINIO_ENDPOINT_URL=http://minio:9000
MINIO_ACCESS_KEY=tryniq
MINIO_SECRET_KEY=tryniq-secret
MINIO_BUCKET=tryniq

REDIS_URL=redis://redis:6379/0

ASR_FINAL_PROVIDER=faster_whisper
ASR_FINAL_MODEL=large-v3-turbo
ASR_FINAL_DEVICE=cpu
ASR_FINAL_COMPUTE_TYPE=int8
ASR_FINAL_LANGUAGE=en
ASR_FINAL_INITIAL_PROMPT="Tryniq, MinIO, TaskIQ, faster-whisper, large-v3-turbo, Postgres, pgvector, Redis, Next.js, FastAPI, Moonshine, Silero, Anthropic, Claude, Ollama, Qwen, Whisper, ECAPA, WebRTC, AudioWorklet, SQLModel, Alembic."

ASR_LIVE_ENABLED=true
ASR_LIVE_PROVIDER=fluid_audio
ASR_LIVE_MODEL=parakeet-tdt-v2
ASR_LIVE_IDLE_TIMEOUT_S=120
ASR_LIVE_AUTH_TOKEN=secret_token

# optional
HF_TOKEN=<token>
