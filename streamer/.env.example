BACKEND_WS_URL=ws://localhost:8000
# Must equal ASR_LIVE_AUTH_TOKEN in backend/.env
WORKER_TOKEN=replace-me

# ASR latency knobs. First update fires at chunk+right; updates every chunk after.
# Defaults: chunk=2s, right=1s -> first partial ~3s, partial cadence 2s.
ASR_CHUNK_S=2.0
ASR_RIGHT_CTX_S=1.0
ASR_LEFT_CTX_S=5.0
ASR_MIN_CONFIRM_S=4.0
